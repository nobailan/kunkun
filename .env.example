# Kun 环境变量配置
# 复制此文件为 .env 并填写实际值

# DeepSeek API 配置
KUN_API_KEY=your_deepseek_api_key_here
# 或使用通用变量
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 模型配置
KUN_MODEL=deepseek-v4-pro
KUN_LIGHT_MODEL=deepseek-v4-flash
KUN_BASE_URL=https://api.deepseek.com

# Agent 配置
KUN_MAX_TURNS=50
KUN_MAX_TOKENS_PER_TURN=64000
KUN_MAX_BUDGET_USD=5.0
KUN_DAILY_BUDGET_USD=20.0

# 工作目录
KUN_WORKSPACE=.

# 权限
# KUN_PERMISSION_MODE=default
# KUN_VERBOSE=1
